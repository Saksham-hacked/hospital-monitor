# ============================================================
# Hospital Monitor — .gitignore
# ============================================================

# ───────────────────────────────────────────────────────────
# Environment variables — NEVER commit these
# ───────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ───────────────────────────────────────────────────────────
# Python / Backend
# ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Virtual environments
venv/
.venv/
env/
hospitalenv/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# mypy
.mypy_cache/

# ───────────────────────────────────────────────────────────
# Node / Frontend
# ───────────────────────────────────────────────────────────
node_modules/
dist/
.vite/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ───────────────────────────────────────────────────────────
# Backup / temp files
# ───────────────────────────────────────────────────────────
*.bak
*.tmp
*.log

# ───────────────────────────────────────────────────────────
# OS junk
# ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ───────────────────────────────────────────────────────────
# IDE / Editor
# ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
